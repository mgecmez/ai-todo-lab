{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=todos.db"
  },
  "Jwt": {
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "RateLimit": {
    "LoginWindowSeconds": 900,
    "LoginPermitLimit": 5,
    "RegisterWindowSeconds": 3600,
    "RegisterPermitLimit": 10
  }
}
